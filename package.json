{
  "name": "@kcenon/public-data-sdk",
  "version": "0.1.0-beta.1",
  "description": "TypeScript SDK for Korean Government Public Data APIs (공공데이터 SDK)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "korea",
    "public-data",
    "api",
    "sdk",
    "typescript",
    "weather",
    "business",
    "address",
    "공공데이터",
    "data.go.kr"
  ],
  "author": "kcenon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kcenon/public_api.git"
  },
  "homepage": "https://github.com/kcenon/public_api",
  "bugs": {
    "url": "https://github.com/kcenon/public_api/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
